# Build stage
FROM golang:1.21-alpine AS builder

# Install build dependencies
RUN apk add --no-cache git make

# Set working directory
WORKDIR /build

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Build autonomous worker
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o autonomous-worker ./cmd/autonomous-worker

# Runtime stage
FROM alpine:latest

# Install runtime dependencies
RUN apk --no-cache add ca-certificates tzdata

# Set working directory
WORKDIR /app

# Copy binary from builder
COPY --from=builder /build/autonomous-worker .

# Copy configs
COPY configs/ ./configs/

# Create output directories
RUN mkdir -p output/specs output/discovery output/strategy output/payloads output/results output/analysis

# Run as non-root user
RUN addgroup -g 1000 appuser && \
    adduser -D -u 1000 -G appuser appuser && \
    chown -R appuser:appuser /app

USER appuser

# Run autonomous worker
CMD ["./autonomous-worker"]

