{
  "execution_order": [
    "/user/login",
    "/pet",
    "/pet/{petId}",
    "/store/order",
    "/store/order/{orderId}",
    "/user"
  ],
  "phases": [
    {
      "description": "Verify basic functionality of key endpoints",
      "endpoints": [
        "/user/login",
        "/pet",
        "/store/order"
      ],
      "name": "smoke"
    },
    {
      "description": "Test detailed functionality of all endpoints",
      "endpoints": [
        "/pet",
        "/pet/{petId}",
        "/store/order",
        "/user",
        "/user/login"
      ],
      "name": "functional"
    },
    {
      "description": "Test interactions between endpoints and authentication",
      "endpoints": [
        "/pet",
        "/pet/{petId}",
        "/store/order",
        "/user",
        "/user/login"
      ],
      "name": "integration"
    }
  ],
  "scenarios": [
    {
      "context_requirements": {
        "context_fields_created": [
          "token"
        ],
        "context_type": "user",
        "creates_context": true,
        "needs_context": false
      },
      "endpoint": "/user/login",
      "scenarios": [
        "login with valid credentials",
        "login with invalid credentials"
      ]
    },
    {
      "context_requirements": {
        "context_fields_created": [
          "id",
          "name"
        ],
        "context_type": "pet",
        "creates_context": true,
        "needs_context": false
      },
      "endpoint": "/pet",
      "scenarios": [
        "create valid pet",
        "create pet with missing fields"
      ]
    },
    {
      "context_requirements": {
        "context_fields_needed": [
          "id"
        ],
        "context_mapping": {
          "path_params.petId": "{{CONTEXT:pet.id}}"
        },
        "context_type": "pet",
        "creates_context": false,
        "depends_on": "/pet",
        "needs_context": true
      },
      "endpoint": "/pet/{petId}",
      "scenarios": [
        "get existing pet",
        "get non-existent pet"
      ]
    },
    {
      "context_requirements": {
        "context_fields_created": [
          "id",
          "petId"
        ],
        "context_type": "order",
        "creates_context": true,
        "needs_context": false
      },
      "endpoint": "/store/order",
      "scenarios": [
        "create valid order",
        "create order with missing fields"
      ]
    },
    {
      "context_requirements": {
        "context_fields_needed": [
          "id"
        ],
        "context_mapping": {
          "path_params.orderId": "{{CONTEXT:order.id}}"
        },
        "context_type": "order",
        "creates_context": false,
        "depends_on": "/store/order",
        "needs_context": true
      },
      "endpoint": "/store/order/{orderId}",
      "scenarios": [
        "get existing order",
        "get non-existent order"
      ]
    },
    {
      "context_requirements": {
        "context_fields_created": [
          "username"
        ],
        "context_type": "user",
        "creates_context": true,
        "needs_context": false
      },
      "endpoint": "/user",
      "scenarios": [
        "create valid user",
        "create user with missing fields"
      ]
    }
  ],
  "success_criteria": {
    "max_failures": 5,
    "min_coverage": 80
  }
}