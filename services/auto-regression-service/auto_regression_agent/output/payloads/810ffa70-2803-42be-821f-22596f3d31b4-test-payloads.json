  "/employees POST": {
    "raw_response": "{\n  \"positive\": [\n    {\n      \"name\": \"Create new employee\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 201,\n      \"description\": \"Create a new employee\",\n      \"context_capture\": {\"enabled\": true, \"fields\": [\"id\", \"firstName\", \"lastName\"], \"store_as\": \"employee\"}\n    },\n    {\n      \"name\": \"Create employee with valid address\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"Jane\", \"lastName\": \"Doe\", \"email\": \"jane.doe@example.com\", \"jobTitle\": \"Marketing Manager\", \"address\": {\"street\": \"123 Main St\", \"city\": \"Anytown\", \"state\": \"CA\", \"zip\": \"12345\"}},\n      \"expected_status\": 201,\n      \"description\": \"Create a new employee with valid address\",\n      \"context_capture\": {\"enabled\": true, \"fields\": [\"id\", \"firstName\", \"lastName\"], \"store_as\": \"employee\"}\n    },\n    {\n      \"name\": \"Create employee with phone number\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"Bob\", \"lastName\": \"Smith\", \"email\": \"bob.smith@example.com\", \"jobTitle\": \"Sales Representative\", \"phone\": \"+1 123-456-7890\"},\n      \"expected_status\": 201,\n      \"description\": \"Create a new employee with phone number\",\n      \"context_capture\": {\"enabled\": true, \"fields\": [\"id\", \"firstName\", \"lastName\"], \"store_as\": \"employee\"}\n    }\n  ],\n  \"negative\": [\n    {\n      \"name\": \"Missing required field\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 400,\n      \"description\": \"Fail to create employee with missing required field\"\n    },\n    {\n      \"name\": \"Invalid email\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"invalid_email\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 400,\n      \"description\": \"Fail to create employee with invalid email\"\n    },\n    {\n      \"name\": \"Duplicate employee\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 409,\n      \"description\": \"Fail to create duplicate employee\",\n      \"context_required\": {\"type\": \"employee\", \"fields\": [\"email\"]}\n    }\n  ],\n  \"boundary\": [\n    {\n      \"name\": \"Long first name\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"a\".repeat(100), \"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 201,\n      \"description\": \"Create employee with long first name\"\n    },\n    {\n      \"name\": \"Empty job title\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"\"},\n      \"expected_status\": 201,\n      \"description\": \"Create employee with empty job title\"\n    }\n  ]\n}"
  },
