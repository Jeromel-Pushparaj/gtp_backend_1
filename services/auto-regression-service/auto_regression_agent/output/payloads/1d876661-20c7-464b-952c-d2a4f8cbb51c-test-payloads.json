  "/user/login": {
    "raw_response": "{\n  \"positive\": [\n    {\n      \"name\": \"Valid login with username and password\",\n      \"method\": \"GET\",\n      \"path\": \"/user/login\",\n      \"query_params\": {\"username\": \"testuser\", \"password\": \"testpassword\"},\n      \"payload\": null,\n      \"expected_status\": 200,\n      \"description\": \"Successful login with valid credentials\"\n    },\n    {\n      \"name\": \"Valid login with username only\",\n      \"method\": \"GET\",\n      \"path\": \"/user/login\",\n      \"query_params\": {\"username\": \"testuser\"},\n      \"payload\": null,\n      \"expected_status\": 200,\n      \"description\": \"Successful login with valid username\"\n    },\n    {\n      \"name\": \"Valid login with password only\",\n      \"method\": \"GET\",\n      \"path\": \"/user/login\",\n      \"query_params\": {\"password\": \"testpassword\"},\n      \"payload\": null,\n      \"expected_status\": 200,\n      \"description\": \"Successful login with valid password\"\n    }\n  ],\n  \"negative\": [\n    {\n      \"name\": \"Invalid login with missing username\",\n      \"method\": \"GET\",\n      \"path\": \"/user/login\",\n      \"query_params\": {\"password\": \"testpassword\"},\n      \"payload\": null,\n      \"expected_status\": 400,\n      \"description\": \"Failed login with missing username\"\n    },\n    {\n      \"name\": \"Invalid login with missing password\",\n      \"method\": \"GET\",\n      \"path\": \"/user/login\",\n      \"query_params\": {\"username\": \"testuser\"},\n      \"payload\": null,\n      \"expected_status\": 400,\n      \"description\": \"Failed login with missing password\"\n    },\n    {\n      \"name\": \"Invalid login with invalid credentials\",\n      \"method\": \"GET\",\n      \"path\": \"/user/login\",\n      \"query_params\": {\"username\": \"wronguser\", \"password\": \"wrongpassword\"},\n      \"payload\": null,\n      \"expected_status\": 401,\n      \"description\": \"Failed login with invalid credentials\"\n    }\n  ],\n  \"boundary\": [\n    {\n      \"name\": \"Empty username and password\",\n      \"method\": \"GET\",\n      \"path\": \"/user/login\",\n      \"query_params\": {\"username\": \"\", \"password\": \"\"},\n      \"payload\": null,\n      \"expected_status\": 400,\n      \"description\": \"Failed login with empty username and password\"\n    },\n    {\n      \"name\": \"Long username and password\",\n      \"method\": \"GET\",\n      \"path\": \"/user/login\",\n      \"query_params\": {\"username\": \"verylongusername\".repeat(10), \"password\": \"verylongpassword\".repeat(10)},\n      \"payload\": null,\n      \"expected_status\": 200,\n      \"description\": \"Successful login with long username and password\"\n    }\n  ]\n}"
  }
