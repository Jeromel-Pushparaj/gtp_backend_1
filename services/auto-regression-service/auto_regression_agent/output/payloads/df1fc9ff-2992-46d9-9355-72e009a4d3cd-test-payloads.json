  "DELETE /pet/{petId}": {
    "boundary": [
      {
        "description": "Fallback: Boundary test with edge values",
        "expected_status": 200,
        "method": "DELETE",
        "name": "Boundary DELETE request",
        "path": "/pet/{petId}",
        "path_params": {
          "petId": 1
        }
      }
    ],
    "fallback": true,
    "negative": [
      {
        "description": "Fallback: Negative test with invalid data",
        "expected_status": 400,
        "method": "DELETE",
        "name": "Invalid DELETE request",
        "path": "/pet/{petId}",
        "path_params": {
          "petId": "invalid_value_!@#"
        }
      }
    ],
    "positive": [
      {
        "context_required": {
          "fields": [
            "id"
          ],
          "type": "resource"
        },
        "description": "Fallback: Basic positive test for DELETE /pet/{petId}",
        "expected_status": 200,
        "method": "DELETE",
        "name": "Basic DELETE request",
        "path": "/pet/{petId}",
        "path_params": {
          "petId": "{{CONTEXT:pet.id}}"
        }
      }
    ]
  },
