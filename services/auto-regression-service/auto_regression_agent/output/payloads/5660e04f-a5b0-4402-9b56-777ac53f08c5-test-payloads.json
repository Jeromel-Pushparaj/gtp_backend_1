  "/employees POST": {
    "raw_response": "{\n  \"positive\": [\n    {\n      \"name\": \"Create new employee with valid data\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 201,\n      \"description\": \"Create a new employee with valid data\",\n      \"context_capture\": {\"enabled\": true, \"fields\": [\"id\", \"firstName\", \"lastName\"], \"store_as\": \"employee\"}\n    },\n    {\n      \"name\": \"Create new employee with valid data and address\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"Jane\", \"lastName\": \"Smith\", \"email\": \"jane.smith@example.com\", \"jobTitle\": \"Marketing Manager\", \"address\": {\"street\": \"123 Main St\", \"city\": \"Anytown\", \"state\": \"CA\", \"zip\": \"12345\"}},\n      \"expected_status\": 201,\n      \"description\": \"Create a new employee with valid data and address\",\n      \"context_capture\": {\"enabled\": true, \"fields\": [\"id\", \"firstName\", \"lastName\"], \"store_as\": \"employee\"}\n    },\n    {\n      \"name\": \"Create new employee with valid data and phone number\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"Bob\", \"lastName\": \"Johnson\", \"email\": \"bob.johnson@example.com\", \"jobTitle\": \"Sales Representative\", \"phone\": {\"type\": \"work\", \"number\": \"123-456-7890\"}},\n      \"expected_status\": 201,\n      \"description\": \"Create a new employee with valid data and phone number\",\n      \"context_capture\": {\"enabled\": true, \"fields\": [\"id\", \"firstName\", \"lastName\"], \"store_as\": \"employee\"}\n    }\n  ],\n  \"negative\": [\n    {\n      \"name\": \"Create new employee with missing first name\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 400,\n      \"description\": \"Create a new employee with missing required field (firstName)\"\n    },\n    {\n      \"name\": \"Create new employee with invalid email\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"invalid_email\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 400,\n      \"description\": \"Create a new employee with invalid email\"\n    },\n    {\n      \"name\": \"Create new employee with duplicate email\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 409,\n      \"description\": \"Create a new employee with duplicate email\",\n      \"context_required\": {\"type\": \"employee\", \"fields\": [\"email\"]}\n    }\n  ],\n  \"boundary\": [\n    {\n      \"name\": \"Create new employee with very long first name\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"a\".repeat(100), \"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": \"Software Engineer\"},\n      \"expected_status\": 201,\n      \"description\": \"Create a new employee with very long first name\"\n    },\n    {\n      \"name\": \"Create new employee with null job title\",\n      \"method\": \"POST\",\n      \"path\": \"/employees\",\n      \"payload\": {\"firstName\": \"John\", \"lastName\": \"Doe\", \"email\": \"john.doe@example.com\", \"jobTitle\": null},\n      \"expected_status\": 201,\n      \"description\": \"Create a new employee with null job title\"\n    }\n  ]\n}"
  },
