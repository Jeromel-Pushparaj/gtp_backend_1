{
  "base_url": "https://petstore3.swagger.io",
  "complexity": 8,
  "context_type_mappings": {
    "buyer": "customer",
    "entity": "pet",
    "item": "pet",
    "purchase": "order",
    "resource": "pet"
  },
  "dependencies": {
    "/pet/{petId}": [
      "/pet"
    ],
    "/store/order/{orderId}": [
      "/store/order"
    ],
    "/user/{username}": [
      "/user"
    ]
  },
  "key_endpoints": [
    "/pet",
    "/store/inventory",
    "/store/order",
    "/user"
  ],
  "recommendations": [
    "Test CRUD operations for /pet endpoint first",
    "Verify security settings for OAuth2",
    "Test business logic for /store/order endpoint"
  ],
  "security": {
    "scopes": [
      "read:pets",
      "write:pets"
    ],
    "type": "oauth2"
  },
  "test_priorities": [
    {
      "endpoint": "/pet",
      "priority": 1,
      "reason": "CRUD operations"
    },
    {
      "endpoint": "/store/inventory",
      "priority": 2,
      "reason": "important data"
    },
    {
      "endpoint": "/store/order",
      "priority": 3,
      "reason": "business logic"
    },
    {
      "endpoint": "/user",
      "priority": 4,
      "reason": "user authentication"
    }
  ]
}