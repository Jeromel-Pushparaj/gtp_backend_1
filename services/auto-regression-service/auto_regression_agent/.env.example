# OpenTest Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Groq API Configuration (Currently Active)
# ============================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ============================================
# GitHub Configuration
# ============================================
# Get your Personal Access Token from: https://github.com/settings/tokens
GITHUB_PAT_TOKEN=your-github-pat-token-here
GITHUB_URL=https://github.com/your-org/your-repo
GITHUB_BRANCH=main

# ============================================
# OpenAI API Configuration (For Future Use - Currently Commented Out)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Optional: Database Configuration
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=opentest
POSTGRES_USER=opentest
POSTGRES_PASSWORD=your-postgres-password-here
DB_PASSWORD=your-postgres-password-here

# ============================================
# Optional: Redis Configuration
# ============================================
REDIS_PASSWORD=

# ============================================
# Optional: Security Configuration
# ============================================
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# ============================================
# Optional: Storage Configuration (S3/MinIO)
# ============================================
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================
# Optional: Notifications
# ============================================
SLACK_WEBHOOK_URL=
EMAIL_USERNAME=
EMAIL_PASSWORD=

