# Jira Trigger Service Environment Variables
# Copy this file to .env and fill in the values

# Service Configuration
SERVICE_NAME=jira-trigger-service
SERVICE_PORT=8081
SERVICE_HOST=0.0.0.0

# Jira Configuration
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TRIGGER_CREATED=jira.trigger.created
KAFKA_GROUP_ID=jira-trigger-service

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=jira_trigger_db

# Logging
LOG_LEVEL=debug
ENVIRONMENT=development

