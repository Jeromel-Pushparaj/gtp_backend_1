# Onboarding Service Environment Variables
# Copy this file to .env and fill in the values

# Service Configuration
SERVICE_NAME=onboarding-service
SERVICE_PORT=8084
SERVICE_HOST=0.0.0.0

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_SERVICE_ONBOARDED=service.onboarded
KAFKA_GROUP_ID=onboarding-service

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=onboarding_db

# Email Configuration (if needed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Logging
LOG_LEVEL=debug
ENVIRONMENT=development

