# Approval Service Environment Variables
# Copy this file to .env and fill in the values

# Service Configuration
SERVICE_NAME=approval-service
SERVICE_PORT=8083
SERVICE_HOST=0.0.0.0

# Slack Configuration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_APPROVAL_REQUESTED=approval.requested
KAFKA_TOPIC_APPROVAL_COMPLETED=approval.completed
KAFKA_GROUP_ID=approval-service

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=approval_db

# Logging
LOG_LEVEL=debug
ENVIRONMENT=development

