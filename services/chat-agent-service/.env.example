# Chat Agent Service Environment Variables
# Copy this file to .env and fill in the values

# Service Configuration
SERVICE_NAME=chat-agent-service
SERVICE_PORT=8082
SERVICE_HOST=0.0.0.0

# AI/LLM Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_CHAT_REQUEST=chat.request
KAFKA_TOPIC_CHAT_RESPONSE=chat.response
KAFKA_GROUP_ID=chat-agent-service

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=chat_agent_db

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=debug
ENVIRONMENT=development

