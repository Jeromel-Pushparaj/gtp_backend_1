# Root Environment Variables
# Copy this file to .env and fill in the values

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=gtp-platform

# Database Configuration (if shared)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=gtp_platform

# Redis Configuration (if shared)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Environment
ENVIRONMENT=development
LOG_LEVEL=debug

