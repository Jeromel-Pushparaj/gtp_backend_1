# Sonar Shell Test - Environment Configuration
# Copy this file to .env and fill in your actual values

# ═══════════════════════════════════════════════════════════════
# Required Configuration
# ═══════════════════════════════════════════════════════════════

# GitHub Personal Access Token
# Get it from: https://github.com/settings/tokens
# Required scopes: repo, admin:org -> read:org
GITHUB_PAT=your_github_pat_here

# GitHub Organization Name
GITHUB_ORG=your_org_name_here

# ═══════════════════════════════════════════════════════════════
# Optional Configuration
# ═══════════════════════════════════════════════════════════════

# SonarCloud Token (optional - only needed for SonarCloud features)
# Get it from: https://sonarcloud.io/account/security
SONAR_TOKEN=

# SonarCloud Organization Key (defaults to GITHUB_ORG if not set)
SONAR_ORG_KEY=

# Default Git Branch (default: main)
DEFAULT_BRANCH=main

# Environment Name (default: production)
ENVIRONMENT_NAME=production

# Database Path (default: ./data/metrics.db)
DATABASE_PATH=./data/metrics.db

# ═══════════════════════════════════════════════════════════════
# Jira Configuration (optional - only needed for Jira features)
# ═══════════════════════════════════════════════════════════════

# Jira API Token
# Get it from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=

# Jira Domain (e.g., yourcompany.atlassian.net)
JIRA_DOMAIN=

# Jira Email (your Atlassian account email)
JIRA_EMAIL=

