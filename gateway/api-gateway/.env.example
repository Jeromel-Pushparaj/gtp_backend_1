# 🌐 API Gateway Environment Variables
# Copy this file to .env and fill in the values

# ═══════════════════════════════════════════════════════════
# 🌐 Gateway Configuration
# ═══════════════════════════════════════════════════════════
GATEWAY_PORT=8000
GATEWAY_HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════
# 🔐 Security & Authentication
# ═══════════════════════════════════════════════════════════
# JWT secret key - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRATION=24h

# CORS allowed origins (comma-separated or use * for all)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ═══════════════════════════════════════════════════════════
# ⚡ Rate Limiting
# ═══════════════════════════════════════════════════════════
# Maximum number of requests per duration
RATE_LIMIT_REQUESTS=100
# Duration for rate limiting (e.g., 1m, 1h, 30s)
RATE_LIMIT_DURATION=1m

# ═══════════════════════════════════════════════════════════
# 🎯 Backend Service URLs
# ═══════════════════════════════════════════════════════════

# 🎫 Jira Trigger Service (Port 8086)
# Handles Jira issue creation and management
JIRA_TRIGGER_SERVICE_URL=http://localhost:8086

# 🤖 Chat Agent Service (Port 8082)
# AI-powered chat agent with Groq integration
CHAT_AGENT_SERVICE_URL=http://localhost:8082

# ✅ Approval Service (Port 8083)
# Slack approval workflows and notifications
APPROVAL_SERVICE_URL=http://localhost:8083

# 📦 Onboarding Service (Port 8084)
# Service catalog and onboarding management
ONBOARDING_SERVICE_URL=http://localhost:8084

# 📊 ScoreCard Service (Port 8085)
# Service scorecard evaluations and metrics
SCORECARD_SERVICE_URL=http://localhost:8085

# 🔍 SonarShell Service (Port 8080)
# SonarCloud automation and code quality metrics
SONAR_SHELL_SERVICE_URL=http://localhost:8080

# ═══════════════════════════════════════════════════════════
# 📊 Kafka Configuration (Optional)
# ═══════════════════════════════════════════════════════════
# Kafka brokers for event publishing (if needed)
KAFKA_BROKERS=localhost:9092

# ═══════════════════════════════════════════════════════════
# 📝 Notes
# ═══════════════════════════════════════════════════════════
# 1. Make sure all backend services are running on their respective ports
# 2. Update service URLs if running in Docker or different hosts
# 3. For production, use proper JWT secret and restrict CORS origins
# 4. Adjust rate limiting based on your traffic patterns
# 5. The gateway runs on port 8000 by default (different from services)

